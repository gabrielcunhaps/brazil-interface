# Brazil Intelligence Dashboard - Environment Variables

# === Required for full functionality ===

# NASA FIRMS (fire hotspot data) - Get free key at: https://firms.modaps.eosdis.nasa.gov/api/area/
FIRMS_MAP_KEY=

# === Optional (enhance functionality) ===

# Cesium Ion access token - Get free at: https://ion.cesium.com/
CESIUM_ION_TOKEN=

# INMET weather API token - Register at: https://apitempo.inmet.gov.br/
INMET_TOKEN=

# Portal da Transparencia API key - Register at: https://api.portaldatransparencia.gov.br/
TRANSPARENCIA_KEY=

# OpenSky Network credentials (higher rate limits) - Register at: https://opensky-network.org/
OPENSKY_USERNAME=
OPENSKY_PASSWORD=

# === Server Configuration ===
BACKEND_PORT=8000
FRONTEND_PORT=5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
